// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Party {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  email      String?
  guests     Guest[]
  createdAt  DateTime @default(now())
}

model Guest {
  id             String          @id @default(cuid())
  name           String
  email          String?
  partyId        String
  party          Party           @relation(fields: [partyId], references: [id], onDelete: Cascade)
  rsvpResponse   RSVPResponse?
  seatAssignment SeatAssignment?
  createdAt      DateTime        @default(now())
}

model RSVPResponse {
  id          String   @id @default(cuid())
  guestId     String   @unique
  guest       Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  attending   Boolean
  answers     Json     @default("{}")
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomQuestion {
  id       String  @id @default(cuid())
  label    String
  type     String  // "text" | "select" | "boolean"
  options  String? // JSON-encoded string array for select type
  required Boolean @default(false)
  order    Int     @default(0)
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  published Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model RegistryLink {
  id    String @id @default(cuid())
  title String
  url   String
  order Int    @default(0)
}

model Table {
  id          String           @id @default(cuid())
  name        String
  capacity    Int
  assignments SeatAssignment[]
}

model SeatAssignment {
  id      String @id @default(cuid())
  tableId String
  table   Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  guestId String @unique
  guest   Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)
  seat    Int?
}

model EmailLog {
  id       String   @id @default(cuid())
  to       String
  subject  String
  type     String   // "invite" | "save-the-date" | "rsvp-confirmation" | "custom"
  sentAt   DateTime @default(now())
  resendId String?
}

model SiteSettings {
  id          String   @id @default("singleton")
  weddingDate DateTime?
  coupleNames String   @default("The Happy Couple")
  siteTitle   String   @default("Our Wedding")
  rsvpCutoff  DateTime?
  updatedAt   DateTime @updatedAt
}
