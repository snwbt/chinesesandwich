<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BackgroundSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Direction="270"
                                  Color="#000000" Opacity="0.06"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardBorderCompact" TargetType="Border" BasedOn="{StaticResource CardBorder}">
        <Setter Property="Padding" Value="12"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style x:Key="SectionHeader" TargetType="TextBlock" BasedOn="{StaticResource H2Text}">
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

</ResourceDictionary>
