<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <Color x:Key="BackgroundPrimaryColor">#FAFAF8</Color>
    <Color x:Key="BackgroundSecondaryColor">#FFFFFF</Color>
    <Color x:Key="BackgroundSurfaceColor">#F5F0EB</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#E8E0D8</Color>
    <Color x:Key="BorderSubtleColor">#F0EBE5</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#2C2825</Color>
    <Color x:Key="TextSecondaryColor">#6B6560</Color>
    <Color x:Key="TextTertiaryColor">#9B9590</Color>

    <!-- Accent -->
    <Color x:Key="AccentPrimaryColor">#C4A882</Color>
    <Color x:Key="AccentPrimaryHoverColor">#B89B74</Color>
    <Color x:Key="AccentSecondaryColor">#D4A5A5</Color>
    <Color x:Key="AccentSecondaryLightColor">#F0DEDE</Color>

    <!-- Semantic -->
    <Color x:Key="SuccessColor">#7BA887</Color>
    <Color x:Key="SuccessLightColor">#E8F0EB</Color>
    <Color x:Key="WarningColor">#D4A843</Color>
    <Color x:Key="WarningLightColor">#FDF5E6</Color>
    <Color x:Key="DangerColor">#C47070</Color>
    <Color x:Key="DangerLightColor">#FAEAEA</Color>

    <!-- Partners -->
    <Color x:Key="PartnerAColor">#C4A882</Color>
    <Color x:Key="PartnerBColor">#D4A5A5</Color>
    <Color x:Key="PartnerALightColor">#F5EDE0</Color>
    <Color x:Key="PartnerBLightColor">#F0DEDE</Color>

    <!-- Sidebar -->
    <Color x:Key="SidebarBackgroundColor">#2C2825</Color>
    <Color x:Key="SidebarTextColor">#E8E0D8</Color>
    <Color x:Key="SidebarActiveColor">#C4A882</Color>
    <Color x:Key="SidebarHoverColor">#3D3835</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundPrimaryBrush" Color="{StaticResource BackgroundPrimaryColor}"/>
    <SolidColorBrush x:Key="BackgroundSecondaryBrush" Color="{StaticResource BackgroundSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundSurfaceBrush" Color="{StaticResource BackgroundSurfaceColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentPrimaryHoverBrush" Color="{StaticResource AccentPrimaryHoverColor}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentSecondaryLightBrush" Color="{StaticResource AccentSecondaryLightColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource DangerLightColor}"/>
    <SolidColorBrush x:Key="PartnerABrush" Color="{StaticResource PartnerAColor}"/>
    <SolidColorBrush x:Key="PartnerBBrush" Color="{StaticResource PartnerBColor}"/>
    <SolidColorBrush x:Key="PartnerALightBrush" Color="{StaticResource PartnerALightColor}"/>
    <SolidColorBrush x:Key="PartnerBLightBrush" Color="{StaticResource PartnerBLightColor}"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackgroundColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

</ResourceDictionary>
