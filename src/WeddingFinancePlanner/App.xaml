<Application x:Class="WeddingFinancePlanner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WeddingFinancePlanner.ViewModels"
             xmlns:views="clr-namespace:WeddingFinancePlanner.Views"
             ShutdownMode="OnLastWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Themes/Typography.xaml"/>
                <ResourceDictionary Source="Themes/Buttons.xaml"/>
                <ResourceDictionary Source="Themes/Cards.xaml"/>
                <ResourceDictionary Source="Themes/Inputs.xaml"/>
                <ResourceDictionary Source="Themes/DataGrids.xaml"/>
                <ResourceDictionary Source="Themes/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ViewModel → View mappings (must be direct children of ResourceDictionary, not in MergedDictionaries) -->
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VendorListViewModel}">
                <views:VendorListView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VendorDetailViewModel}">
                <views:VendorDetailView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ItemListViewModel}">
                <views:ItemListView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ItemDetailViewModel}">
                <views:ItemDetailView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PaymentListViewModel}">
                <views:PaymentListView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PaymentDetailViewModel}">
                <views:PaymentDetailView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PaymentMethodListViewModel}">
                <views:PaymentMethodListView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PaymentMethodDetailViewModel}">
                <views:PaymentMethodDetailView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SplitSummaryViewModel}">
                <views:SplitSummaryView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
