<UserControl x:Class="WeddingFinancePlanner.Views.VendorDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WeddingFinancePlanner.Converters"
             Background="{StaticResource BackgroundPrimaryBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="640">
            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title}" Style="{StaticResource H1Text}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}"
                        Visibility="{Binding IsNew, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
                    <Button.Resources>
                        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
                    </Button.Resources>
                    Delete
                </Button>
            </Grid>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <!-- Name -->
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Vendor Name *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Category -->
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Category" Style="{StaticResource FormLabel}"/>
                        <ComboBox SelectedItem="{Binding Category}">
                            <ComboBoxItem>Venue</ComboBoxItem>
                            <ComboBoxItem>Catering</ComboBoxItem>
                            <ComboBoxItem>Photography</ComboBoxItem>
                            <ComboBoxItem>Videography</ComboBoxItem>
                            <ComboBoxItem>Florist</ComboBoxItem>
                            <ComboBoxItem>Music</ComboBoxItem>
                            <ComboBoxItem>Attire</ComboBoxItem>
                            <ComboBoxItem>Hair &amp; Makeup</ComboBoxItem>
                            <ComboBoxItem>Stationery</ComboBoxItem>
                            <ComboBoxItem>Transportation</ComboBoxItem>
                            <ComboBoxItem>Decor</ComboBoxItem>
                            <ComboBoxItem>Cake</ComboBoxItem>
                            <ComboBoxItem>Favors</ComboBoxItem>
                            <ComboBoxItem>Officiant</ComboBoxItem>
                            <ComboBoxItem>Planner</ComboBoxItem>
                            <ComboBoxItem>Rentals</ComboBoxItem>
                            <ComboBoxItem>Other</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <!-- Contract Total -->
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Contract Total" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding ContractTotal, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Contact Name -->
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Contact Name" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding ContactName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Contact Email -->
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Contact Email" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding ContactEmail, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Contact Phone -->
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Contact Phone" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding ContactPhone, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Notes -->
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Notes" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Margin="0,0,8,0">
                            Cancel
                        </Button>
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}">
                            Save Vendor
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
