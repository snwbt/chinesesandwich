<UserControl x:Class="WeddingFinancePlanner.Views.PaymentDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WeddingFinancePlanner.Converters"
             Background="{StaticResource BackgroundPrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="640">
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title}" Style="{StaticResource H1Text}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Style="{StaticResource DangerButton}" Command="{Binding DeleteCommand}"
                        Visibility="{Binding IsNew, Converter={StaticResource BoolVis}, ConverterParameter=invert}">Delete</Button>
            </Grid>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Description" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Amount *" Style="{StaticResource FormLabel}"/>
                        <TextBox Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Due Date" Style="{StaticResource FormLabel}"/>
                            <DatePicker SelectedDate="{Binding DueDate}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Paid Date" Style="{StaticResource FormLabel}"/>
                            <DatePicker SelectedDate="{Binding PaidDate}"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Vendor" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding Vendors}" SelectedValuePath="Id"
                                  SelectedValue="{Binding VendorId}" DisplayMemberPath="Name"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Item" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding VendorItems}" SelectedValuePath="Id"
                                  SelectedValue="{Binding ItemId}" DisplayMemberPath="Name"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource FormRow}">
                        <TextBlock Text="Payment Method" Style="{StaticResource FormLabel}"/>
                        <ComboBox ItemsSource="{Binding PaymentMethods}" SelectedValuePath="Id"
                                  SelectedValue="{Binding PaymentMethodId}" DisplayMemberPath="Name"/>
                    </StackPanel>

                    <!-- Split Rule -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,0" Margin="0,8,0,16">
                        <StackPanel>
                            <TextBlock Text="Split Rule" Style="{StaticResource H3Text}" Margin="0,0,0,12"/>
                            <StackPanel Style="{StaticResource FormRow}">
                                <TextBlock Text="Split Type" Style="{StaticResource FormLabel}"/>
                                <ComboBox SelectedItem="{Binding SplitType}">
                                    <ComboBoxItem>FiftyFifty</ComboBoxItem>
                                    <ComboBoxItem>Percentage</ComboBoxItem>
                                    <ComboBoxItem>CustomAmount</ComboBoxItem>
                                    <ComboBoxItem>OnePartnerPays</ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Margin="0,0,8,0">Cancel</Button>
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}">Save Payment</Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
