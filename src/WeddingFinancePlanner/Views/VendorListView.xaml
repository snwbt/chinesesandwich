<UserControl x:Class="WeddingFinancePlanner.Views.VendorListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WeddingFinancePlanner.Converters"
             Background="{StaticResource BackgroundPrimaryBrush}">
    <UserControl.Resources>
        <conv:EnumDescriptionConverter x:Key="EnumDesc"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Vendors" Style="{StaticResource H1Text}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                    Command="{Binding AddVendorCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconAdd}" Width="14" Height="14" Margin="0,0,6,0"
                          Fill="White" Stretch="Uniform"/>
                    <TextBlock Text="Add Vendor"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Search vendors..."/>
                <ComboBox Grid.Column="2" ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          DisplayMemberPath="."
                          xmlns:sys="clr-namespace:System;assembly=mscorlib"
                          xmlns:enums="clr-namespace:WeddingFinancePlanner.Models.Enums"/>
            </Grid>
        </Border>

        <!-- Vendor Cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredVendors}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Width="280" Margin="0,0,16,16"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.EditVendorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource H3Text}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Column="1" Background="{StaticResource AccentSecondaryLightBrush}"
                                            CornerRadius="6" Padding="6,3">
                                        <TextBlock Text="{Binding Category, Converter={StaticResource EnumDesc}}"
                                                   FontSize="11" Foreground="{StaticResource AccentSecondaryBrush}"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="{Binding ContactName}" Style="{StaticResource BodySmallText}"
                                           Visibility="{Binding ContactName, Converter={StaticResource BoolVis}}"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Contract Total" Style="{StaticResource CaptionText}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource H3Text}"
                                               Foreground="{StaticResource AccentPrimaryBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="${0:N2}">
                                                <Binding Path="ContractTotal"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding FilteredVendors.Count, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <Path Data="{StaticResource IconVendors}" Width="48" Height="48"
                  Fill="{StaticResource BorderBrush}" Stretch="Uniform" HorizontalAlignment="Center"/>
            <TextBlock Text="No vendors yet" Style="{StaticResource H2Text}"
                       HorizontalAlignment="Center" Margin="0,16,0,8"/>
            <TextBlock Text="Add your first vendor to get started" Style="{StaticResource BodySecondaryText}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
