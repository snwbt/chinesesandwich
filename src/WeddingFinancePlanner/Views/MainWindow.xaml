<Window x:Class="WeddingFinancePlanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WeddingFinancePlanner.ViewModels"
        xmlns:views="clr-namespace:WeddingFinancePlanner.Views"
        Title="Wedding Finance Planner"
        MinWidth="1100" MinHeight="700"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundPrimaryBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VendorListViewModel}">
            <views:VendorListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VendorDetailViewModel}">
            <views:VendorDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ItemListViewModel}">
            <views:ItemListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ItemDetailViewModel}">
            <views:ItemDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PaymentListViewModel}">
            <views:PaymentListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PaymentDetailViewModel}">
            <views:PaymentDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PaymentMethodListViewModel}">
            <views:PaymentMethodListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PaymentMethodDetailViewModel}">
            <views:PaymentMethodDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SplitSummaryViewModel}">
            <views:SplitSummaryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                    <StackPanel>
                        <Path Data="{StaticResource IconRing}" Fill="{StaticResource SidebarActiveBrush}"
                              Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Left"/>
                        <TextBlock Text="Wedding Planner" Foreground="{StaticResource SidebarTextBrush}"
                                   FontSize="15" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="Finance Tracker" Foreground="{StaticResource SidebarActiveBrush}"
                                   FontSize="11" Opacity="0.8"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource SidebarHoverBrush}" Margin="16,0"/>

                <!-- Settings pinned to bottom -->
                <Border DockPanel.Dock="Bottom" Padding="0,8,0,16">
                    <Button Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSettings}" Width="16" Height="16" Margin="0,0,10,0"
                                  Fill="{StaticResource SidebarTextBrush}" Stretch="Uniform"/>
                            <TextBlock Text="Settings" Foreground="{StaticResource SidebarTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">
                    <Button Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToDashboardCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDashboard}" Width="16" Height="16" Margin="0,0,10,0"
                                  Fill="{StaticResource SidebarTextBrush}" Stretch="Uniform"/>
                            <TextBlock Text="Dashboard" Foreground="{StaticResource SidebarTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToVendorsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconVendors}" Width="16" Height="16" Margin="0,0,10,0"
                                  Fill="{StaticResource SidebarTextBrush}" Stretch="Uniform"/>
                            <TextBlock Text="Vendors" Foreground="{StaticResource SidebarTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToItemsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconItems}" Width="16" Height="16" Margin="0,0,10,0"
                                  Fill="{StaticResource SidebarTextBrush}" Stretch="Uniform"/>
                            <TextBlock Text="Items" Foreground="{StaticResource SidebarTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToPaymentsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPayments}" Width="16" Height="16" Margin="0,0,10,0"
                                  Fill="{StaticResource SidebarTextBrush}" Stretch="Uniform"/>
                            <TextBlock Text="Payments" Foreground="{StaticResource SidebarTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToPaymentMethodsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPaymentMethods}" Width="16" Height="16" Margin="0,0,10,0"
                                  Fill="{StaticResource SidebarTextBrush}" Stretch="Uniform"/>
                            <TextBlock Text="Payment Methods" Foreground="{StaticResource SidebarTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateToSplitSummaryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSplit}" Width="16" Height="16" Margin="0,0,10,0"
                                  Fill="{StaticResource SidebarTextBrush}" Stretch="Uniform"/>
                            <TextBlock Text="Split Summary" Foreground="{StaticResource SidebarTextBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"
                        Background="{StaticResource BackgroundPrimaryBrush}"/>
    </Grid>
</Window>
