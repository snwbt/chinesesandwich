<UserControl x:Class="WeddingFinancePlanner.Views.PaymentMethodListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WeddingFinancePlanner.Converters"
             Background="{StaticResource BackgroundPrimaryBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:EnumDescriptionConverter x:Key="EnumDesc"/>
        <conv:PartnerToColorConverter x:Key="PartnerColor"/>
    </UserControl.Resources>
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Payment Methods" Style="{StaticResource H1Text}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding AddMethodCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconAdd}" Width="14" Height="14" Margin="0,0,6,0" Fill="White" Stretch="Uniform"/>
                    <TextBlock Text="Add Method"/>
                </StackPanel>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Methods}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.EditMethodCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource H3Text}"/>
                                    <TextBlock Text="{Binding Type, Converter={StaticResource EnumDesc}}"
                                               Style="{StaticResource BodySmallText}"/>
                                </StackPanel>
                                <Border Grid.Column="1" Margin="0,0,12,0" CornerRadius="6" Padding="8,4"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Owner, Converter={StaticResource PartnerColor}}"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding Owner}" FontSize="11" Foreground="White"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding LastFourDigits, StringFormat='···· {0}'}"
                                           Style="{StaticResource BodySmallText}" VerticalAlignment="Center"
                                           Visibility="{Binding LastFourDigits, Converter={StaticResource BoolVis}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding Methods.Count, Converter={StaticResource BoolVis}, ConverterParameter=invert}">
            <Path Data="{StaticResource IconPaymentMethods}" Width="48" Height="48" Fill="{StaticResource BorderBrush}" Stretch="Uniform" HorizontalAlignment="Center"/>
            <TextBlock Text="No payment methods yet" Style="{StaticResource H2Text}" HorizontalAlignment="Center" Margin="0,16,0,8"/>
            <TextBlock Text="Add cards and accounts to track who paid what" Style="{StaticResource BodySecondaryText}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
