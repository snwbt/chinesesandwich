<UserControl x:Class="WeddingFinancePlanner.Views.SplitSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WeddingFinancePlanner.Converters"
             Background="{StaticResource BackgroundPrimaryBrush}">
    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="Currency"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32">
            <TextBlock Text="Split Summary" Style="{StaticResource H1Text}" Margin="0,0,0,24"/>

            <!-- Balance Banner -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,24"
                    Background="{StaticResource AccentSecondaryLightBrush}"
                    BorderBrush="{StaticResource AccentSecondaryBrush}">
                <StackPanel HorizontalAlignment="Center" Margin="0,8">
                    <TextBlock Text="CURRENT BALANCE" Style="{StaticResource CaptionText}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding BalanceSummary}" Style="{StaticResource DisplayText}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Partner Columns -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="{Binding PartnerAName}" Style="{StaticResource H2Text}" Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Total Paid" Style="{StaticResource BodySecondaryText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalPaidByA, StringFormat='${0:N2}'}" Style="{StaticResource H3Text}" Foreground="{StaticResource SuccessBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Total Responsible" Style="{StaticResource BodySecondaryText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalOwedByA, StringFormat='${0:N2}'}" Style="{StaticResource H3Text}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="{Binding PartnerBName}" Style="{StaticResource H2Text}" Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Total Paid" Style="{StaticResource BodySecondaryText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalPaidByB, StringFormat='${0:N2}'}" Style="{StaticResource H3Text}" Foreground="{StaticResource SuccessBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Total Responsible" Style="{StaticResource BodySecondaryText}"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalOwedByB, StringFormat='${0:N2}'}" Style="{StaticResource H3Text}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Breakdown Table -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Payment Breakdown" Style="{StaticResource H2Text}" Margin="0,0,0,16"/>
                    <DataGrid ItemsSource="{Binding Breakdown}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Payment" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Amount, StringFormat='${0:N2}'}" Width="100"/>
                            <DataGridTextColumn Header="Paid By" Binding="{Binding ActualPayer}" Width="100"/>
                            <DataGridTextColumn Header="A's Share" Binding="{Binding PartnerAShare, StringFormat='${0:N2}'}" Width="100"/>
                            <DataGridTextColumn Header="B's Share" Binding="{Binding PartnerBShare, StringFormat='${0:N2}'}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
